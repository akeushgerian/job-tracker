# --- Database ---
# Neon cloud DB (direct, non-pooler connection string):
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- API ---
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters-long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_SECURE=false

# --- Local LLM assistant (Ollama, OpenAI-compatible) ---
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b
LLM_API_KEY=ollama
LLM_MAX_STEPS=6

FRONTEND_URL=http://localhost:5173

# --- Gmail integration (optional — leave blank to disable email sync) ---
# Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials
# Required scopes: gmail.readonly, gmail.metadata
# Redirect URI must be registered in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/email-sync/oauth/callback
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=
# Polling interval in ms (default: 600000 = 10 minutes)
EMAIL_SYNC_INTERVAL_MS=

# --- Job Scout (Serper Google Jobs API) ---
# Free tier 2500 searches/month — sign up at https://serper.dev/
SERPER_API_KEY=
