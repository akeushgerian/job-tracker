# --- Database ---
POSTGRES_USER=jobtracker
POSTGRES_PASSWORD=jobtracker
POSTGRES_DB=jobtracker
# DATABASE_URL is consumed by the backend. Host is "postgres" inside Docker, "localhost" when running the API locally.
DATABASE_URL=postgresql://jobtracker:jobtracker@localhost:5432/jobtracker

# --- API ---
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters-long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_SECURE=false

# --- Local LLM assistant (Ollama, OpenAI-compatible) ---
# In Docker, use http://host.docker.internal:11434/v1 to reach Ollama on the host.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b
LLM_API_KEY=ollama
LLM_MAX_STEPS=6

# --- Frontend ---
VITE_API_URL=http://localhost:3000
